
{
  "format_version": "1.19.50",
  "minecraft:item": {
    "description": {
      "identifier": "bg:wyvern_sword",
       "category": "equipment"
    },
    "components": {
      "minecraft:icon": {
        "texture": "wyvern_sword"
      },
      "minecraft:creative_category": {
        "parent": "itemGroup.name.sword"
      },
      "minecraft:max_stack_size": 1,
      "minecraft:hand_equipped": true,
      "minecraft:damage": 15,
      "minecraft:digger": {
        "use_efficiency": false,
        "destroy_speeds": [
          {
            "block": "minecraft:web",
            "speed": 15
          },
          {
            "block": "minecraft:bamboo",
            "speed": 10
          }
		],
		"on_dig": {
			"event": "hurt"
		  }
	 },
		"minecraft:weapon": {
			"on_hurt_entity": {
				"event": "hurt2"
			}
		},
		"minecraft:durability": {
			"max_durability": 1003,
			"damage_chance": {
				"min": 5,
				"max": 10
			}
		}
	},
	"events": {
  "hurt": {
            "damage": {
              "type": "magic",
              "amount": 1,
              "target": "self"
          }
      },
		"hurt2": {
			"sequence": [
          {
            "damage": {
              "type": "magic",
              "amount": 1,
              "target": "self"
             }
          },
          {
            "run_command": {
              "command":[  
                "damage @e[family=mob, r=2] 12 entity_attack" 
                 ],
              "target": "other"
            }
          }
        ]
		    }
	   }
  }
}