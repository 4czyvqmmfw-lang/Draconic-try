{
  "format_version": "1.17.0",
  "minecraft:block": {
    "description": {
      "identifier": "bg:fusion_crafting_core",
      "properties": {
        "block:rotation": [
          0,
          1,
          2,
          3,
          4,
          5,
          6
        ]
      }
    },
    "components": {
      "minecraft:creative_category":{
      "category": "Construction",
      "group": "itemGroup.name.Construction"
      },
			   "minecraft:geometry": "geometry.fusion_crafting_core",
      "minecraft:destroy_time": 5.0,
      "minecraft:friction": 0.6,
      "minecraft:map_color": "#FFFFFF",
      "minecraft:explosion_resistance": 30,
      "minecraft:block_light_absorption": 0.0,
      "minecraft:block_light_emission": 0.0,
      "minecraft:on_player_placing": {
        "event": "update_rotation"
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "fusion_crafting_core",
          "render_method": "alpha_test"
        }
      },
      "minecraft:on_placed": {
        "event": "ui"
      },
      "minecraft:ticking": {
        "looping": true,
        "range": [
          1,
          1
        ],
        "on_tick": {
          "event": "on_tick",
          "target": "self"
        }
      }
    },
    "permutations": [
      {
        "condition": "query.block_property('block:rotation') == 2",
        "components": {
          "minecraft:rotation": [
            0,
            -180,
            0
          ]
        }
      },
      {
        "condition": "query.block_property('block:rotation') == 3",
        "components": {
          "minecraft:rotation": [
            0,
            0,
            0
          ]
        }
      },
      {
        "condition": "query.block_property('block:rotation') == 4",
        "components": {
          "minecraft:rotation": [
            0,
            -90,
            0
          ]
        }
      },
      {
        "condition": "query.block_property('block:rotation') == 5",
        "components": {
          "minecraft:rotation": [
            0,
            90,
            0
          ]
        }
      }
    ],
    "events": {
      "update_rotation": {
        "set_block_property": {
          "block:rotation": "query.cardinal_facing_2d"
        }
      },
      "ui": {
        "run_command": {
          "command": [
           "summon bg:fusion_crafting_core_container fusion_crafting_core ~ ~ ~"
          ]
        }
      },
      "on_tick": {
        "run_command": {
          "command": [
           "execute unless entity @e[type=bg:fusion_crafting_core_container, r=1] run setblock ~~~ air destroy"
          ]
        }
      }
    }
  }
}
