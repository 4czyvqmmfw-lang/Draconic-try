{
  "format_version": "1.16.100",
  "minecraft:block": {
    "description": {
      "identifier": "bg:particle_generator15",
      "category": "command",
      "properties": {
        "block:rotation": [
          0,
          1,
          2,
          3,
          4,
          5,
          6
        ]
      }
    },
    "components": {
      "minecraft:loot": "loot_tables/blocks/particle_generator.json",
      "minecraft:geometry": "geometry.particle_generator",
      "minecraft:destroy_time": 5.0,
      "minecraft:friction": 0.6,
      "minecraft:map_color": "#FFFFFF",
      "minecraft:explosion_resistance": 30,
      "minecraft:block_light_absorption": 0.0,
      "minecraft:block_light_emission": 0.0,
      "minecraft:on_player_placing": {
        "event": "update_rotation"
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "particle_generator",
          "render_method": "alpha_test"
        }
      },
      "minecraft:on_interact": {
        "event": "troca"
      },
      "minecraft:ticking": {
        "looping": true,
        "range": [
          0.5,
          0.5
        ],
        "on_tick": {
          "event": "on_tick",
          "target": "self"
        }
      }
    },
    "events": {
      "update_rotation": {
        "set_block_property": {
          "block:rotation": "query.cardinal_facing_2d"
        }
      },
    "on_tick": {
				"run_command": {
					"command": [
						"function particle_generator14"
			   	   ]
			  	  }
      },
    "troca": {
				"run_command": {
					"command": [
						"setblock ~~~ bg:particle_generator16",
						"title @p actionbar Particle:Heart Particle"
			   	   ]
			  	  }
      }
    },
    "permutations": [
      {
        "condition": "query.block_property('block:rotation') == 2",
        "components": {
          "minecraft:rotation": [
            0,
            -180,
            0
          ]
        }
      },
      {
        "condition": "query.block_property('block:rotation') == 3",
        "components": {
          "minecraft:rotation": [
            0,
            0,
            0
          ]
        }
      },
      {
        "condition": "query.block_property('block:rotation') == 4",
        "components": {
          "minecraft:rotation": [
            0,
            -90,
            0
          ]
        }
      },
      {
        "condition": "query.block_property('block:rotation') == 5",
        "components": {
          "minecraft:rotation": [
            0,
            90,
            0
          ]
        }
      }
    ]
  }
}